# ---------------------------------- #
# Пример настроек для локальной разработки
# Скопируй в .env и подставь свои значения
# ---------------------------------- #

MODE=LOCAL

# Для Docker замени DB_HOST=booking_db, REDIS_HOST=booking_cache
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=booking

REDIS_HOST=localhost
REDIS_PORT=6379

# Для продакшена сгенерируй свой ключ (openssl rand -hex 32)
JWT_SECRET_KEY="change-me-to-your-own-secret-key"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
